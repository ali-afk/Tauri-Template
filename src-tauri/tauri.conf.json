{
	"$schema": "https://schema.tauri.app/config/2",
	"productName": "Tauri Template",
	"version": "1.0.0",
	"identifier": "com.burglar.tauri-template",
	"build": {
		"beforeDevCommand": "bun dev",
		"beforeBuildCommand": "bun run build",
		"devUrl": "http://localhost:5173",
		"frontendDist": "../build"
	},
	"bundle": {
		"active": true,
		"targets": "all",
		"icon": [
			"icons/32x32.png",
			"icons/128x128.png",
			"icons/128x128@2x.png",
			"icons/icon.icns",
			"icons/icon.ico"
		],
		"resources": [],
		"copyright": "",
		"category": "DeveloperTool",
		"shortDescription": "Personal Tauri starter template",
		"longDescription": "A modern, accessible desktop application built with Tauri + SvelteKit, featuring design tokens, auto-contrast colors, and a component library."
	},
	"app": {
		"windows": [
			{
				"title": "Tauri Template",
				"width": 1200,
				"height": 800,
				"resizable": true,
				"fullscreen": false,
				"minWidth": 800,
				"minHeight": 600
			}
		],
		"security": {
			"csp": null
		}
	}
}
