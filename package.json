{
	"name": "tauri-template",
	"private": true,
	"version": "1.1.0",
	"description": "Personal SvelteKit starter template with design tokens, auto-contrast colors, and component library",
	"license": "MIT",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"clean": "rm -rf .svelte-kit build src-tauri/target .vitest",
		"preview": "vite preview",
		"prepare": "svelte-kit sync",
		"gen": "bun run scripts/gen/index.ts",
		"lint": "bun lint:biome && bun lint:svelte && bun lint:md",
		"lint:md": "dprint fmt",
		"lint:biome": "biome check --fix --no-errors-on-unmatched",
		"lint:svelte": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"watch": "bun lint:svelte --watch",
		"tauri:dev": "tauri dev",
		"tauri:build": "NO_STRIP=true tauri build",
		"test": "bun --bun vitest run",
		"test:watch": "bun --bun vitest",
		"test:coverage": "bun run test --coverage",
		"test:bench": "bun --bun bench",
		"wdio": "wdio run ./wdio.conf.ts",
		"storybook": "storybook dev -p 6006",
		"storybook:build": "storybook build"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.5.1",
		"@chromatic-com/storybook": "^5.2.1",
		"@dprint/markdown": "^0.22.1",
		"@storybook/addon-a11y": "^10.4.6",
		"@storybook/addon-docs": "^10.4.6",
		"@storybook/addon-svelte-csf": "^5.1.2",
		"@storybook/addon-vitest": "^10.4.6",
		"@storybook/sveltekit": "^10.4.6",
		"@sveltejs/adapter-static": "^3.0.10",
		"@sveltejs/kit": "^2.68.0",
		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"@tauri-apps/cli": "^2.11.3",
		"@testing-library/dom": "^10.4.1",
		"@testing-library/jest-dom": "^6.9.1",
		"@testing-library/svelte": "^5.4.2",
		"@testing-library/webdriverio": "^3.2.1",
		"@types/bun": "^1.3.14",
		"@types/node": "^26.0.1",
		"@vitejs/devtools": "^0.3.3",
		"@vitest/browser-webdriverio": "^4.1.9",
		"@vitest/coverage-istanbul": "4.1.9",
		"@wdio/cli": "^9.29.0",
		"@wdio/globals": "^9.29.0",
		"@wdio/junit-reporter": "^9.29.0",
		"@wdio/local-runner": "^9.29.0",
		"@wdio/mocha-framework": "^9.29.0",
		"@wdio/spec-reporter": "^9.29.0",
		"@wdio/tauri-plugin": "^1.1.0",
		"@wdio/tauri-service": "^1.1.0",
		"browserslist": "^4.28.4",
		"dprint": "^0.54.0",
		"expect-webdriverio": "^5.6.9",
		"happy-dom": "^20.10.6",
		"lefthook": "^2.1.9",
		"lightningcss": "^1.32.0",
		"open-props": "^1.7.23",
		"svelte": "^5.56.4",
		"svelte-check": "^4.7.1",
		"storybook": "^10.4.6",
		"typescript": "^6.0.3",
		"vite": "^8.1.0",
		"vite-devtools-svelte": "^0.2.1",
		"vite-plugin-run": "^0.9.0",
		"vitest": "^4.1.9"
	},
	"dependencies": {
		"@tauri-apps/api": "^2.11.1",
		"@tauri-apps/plugin-opener": "^2.5.4",
		"@tauri-apps/plugin-store": "~2.4.3",
		"bezier-easing": "^3.0.1"
	},
	"trustedDependencies": [
		"edgedriver"
	]
}
