{
	"name": "tauri-template",
	"private": true,
	"version": "1.0.0",
	"description": "Personal SvelteKit starter template with design tokens, auto-contrast colors, and component library",
	"license": "MIT",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"clean": "rm -rf .svelte-kit build src-tauri/target .vitest",
		"preview": "vite preview",
		"prepare": "svelte-kit sync",
		"gen": "bun run scripts/gen/index.ts",
		"lint": "bun lint:biome && bun lint:svelte && bun lint:md",
		"lint:md": "dprint fmt",
		"lint:biome": "biome check --fix --no-errors-on-unmatched",
		"lint:svelte": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"watch": "bun lint:svelte --watch",
		"tauri:dev": "tauri dev",
		"tauri:build": "NO_STRIP=true tauri build",
		"test": "bun --bun vitest run",
		"test:watch": "bun --bun vitest",
		"test:coverage": "bun run test --coverage",
		"test:bench": "bun --bun bench"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.5.0",
		"@dprint/markdown": "^0.22.1",
		"@sveltejs/adapter-static": "^3.0.10",
		"@sveltejs/kit": "^2.66.0",
		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"@tauri-apps/cli": "^2.11.3",
		"@testing-library/dom": "^10.4.1",
		"@testing-library/jest-dom": "^6.9.1",
		"@testing-library/svelte": "^5.4.0",
		"@types/bun": "^1.3.14",
		"@vitejs/devtools": "^0.3.3",
		"@vitest/coverage-istanbul": "4.1.9",
		"browserslist": "^4.28.2",
		"dprint": "^0.54.0",
		"happy-dom": "^20.10.6",
		"lefthook": "^2.1.9",
		"lightningcss": "^1.32.0",
		"open-props": "^1.7.23",
		"svelte": "^5.56.3",
		"svelte-check": "^4.6.0",
		"typescript": "^6.0.3",
		"vite": "^8.0.16",
		"vite-devtools-svelte": "^0.2.1",
		"vite-plugin-run": "^0.9.0",
		"vitest": "^4.1.9"
	},
	"dependencies": {
		"@tauri-apps/api": "^2.11.1",
		"@tauri-apps/plugin-opener": "^2.5.4",
		"bezier-easing": "^3.0.1"
	}
}
