{
	"name": "sveltekit-personal-template",
	"private": true,
	"version": "1.0.0",
	"description": "Personal SvelteKit starter template with design tokens, auto-contrast colors, and component library",
	"license": "MIT",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "husky && svelte-kit sync",
		"gen": "bun run ./src/lib/scripts/gen.ts",
		"fix": "biome check --fix --staged --no-errors-on-unmatched && markdownlint-cli2 --fix",
		"fix-svelte": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"fix-all": "bun fix && bun fix-svelte",
		"watch": "bun fix-svelte --watch",
		"tauri:dev": "tauri dev",
		"tauri:build": "NO_STRIP=true tauri build"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.4",
		"@sveltejs/adapter-static": "^3.0.10",
		"@sveltejs/kit": "^2.53.1",
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"@tauri-apps/cli": "^2.10.0",
		"@types/bun": "^1.3.9",
		"bezier-easing": "^3.0.0",
		"browserslist": "^4.28.1",
		"husky": "^9.1.7",
		"lightningcss": "^1.31.1",
		"markdownlint-cli2": "^0.22.0",
		"svelte": "^5.53.3",
		"svelte-check": "^4.4.3",
		"typescript": "^6.0.2",
		"vite": "^8.0.10",
		"vite-plugin-run": "^0.6.1"
	},
	"dependencies": {
		"@tauri-apps/api": "^2.10.1",
		"@tauri-apps/plugin-opener": "^2.5.3",
		"open-props": "^1.7.23"
	}
}
